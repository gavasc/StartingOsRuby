<div>
  <%= tag.div(flash[:alert], style: "color:red") if flash[:alert] %>
  <%= tag.div(flash[:notice], style: "color:green") if flash[:notice] %>

  <%= form_with model: repository do |form| %>
    <div>
      <%= form.label :link, "https://github.com/" %>
      <%= form.text_field :link, required: true %>
    </div>

    <div>
      <%= form.submit "Adicionar repositório", style: "border-radius: 8%; background-color: #edeeec;"%>
    </div>
  <% end %>
</div>
